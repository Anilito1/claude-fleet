{
  "name": "coding-agent-observatory",
  "displayName": "Agent Observatory",
  "description": "See your AI coding agents working — live. Sessions and sub-agents as animated characters, with live token usage and cost.",
  "version": "0.1.0",
  "publisher": "Anilito1",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": { "color": "#0a0b0e", "theme": "dark" },
  "repository": {
    "type": "git",
    "url": "https://github.com/Anilito1/agent-observatory.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": ["ai", "agents", "monitor", "tokens", "dashboard"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentObservatory",
          "title": "Agent Observatory",
          "icon": "resources/activity.png"
        }
      ]
    },
    "views": {
      "agentObservatory": [
        {
          "type": "webview",
          "id": "agentObservatory.view",
          "name": "Observatory",
          "icon": "resources/activity.png"
        }
      ]
    },
    "commands": [
      {
        "command": "agentObservatory.openPanel",
        "title": "Agent Observatory: Ouvrir le moniteur (plein écran)",
        "icon": "$(window)"
      },
      {
        "command": "agentObservatory.newSession",
        "title": "Agent Observatory: Lancer une nouvelle session",
        "icon": "$(add)"
      },
      {
        "command": "agentObservatory.refresh",
        "title": "Agent Observatory: Rafraîchir",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "agentObservatory.openPanel", "when": "view == agentObservatory.view", "group": "navigation@1" },
        { "command": "agentObservatory.newSession", "when": "view == agentObservatory.view", "group": "navigation@2" },
        { "command": "agentObservatory.refresh", "when": "view == agentObservatory.view", "group": "navigation@3" }
      ]
    },
    "configuration": {
      "title": "Agent Observatory",
      "properties": {
        "agentObservatory.projectsDir": {
          "type": "string",
          "default": "",
          "description": "Path to the coding agent transcripts folder. Empty = default location in your home directory."
        },
        "agentObservatory.activeWindowMinutes": {
          "type": "number",
          "default": 180,
          "description": "Une session/agent modifié dans cette fenêtre (minutes) est considéré « récent » et affiché par défaut."
        },
        "agentObservatory.liveWindowSeconds": {
          "type": "number",
          "default": 120,
          "description": "Une session/agent modifié dans cette fenêtre (secondes) est considéré « en direct » (pastille verte pulsée)."
        },
        "agentObservatory.pollIntervalMs": {
          "type": "number",
          "default": 1500,
          "description": "Intervalle de rafraîchissement (ms) du watcher de fichiers."
        },
        "agentObservatory.cliCommand": {
          "type": "string",
          "default": "claude",
          "description": "CLI command used to launch / resume sessions."
        },
        "agentObservatory.pricing": {
          "type": "object",
          "default": {},
          "description": "Surcharge des tarifs ($ / 1M tokens) par famille de modèle. Ex: {\"opus\":{\"input\":15,\"output\":75,\"cacheWrite5m\":18.75,\"cacheWrite1h\":30,\"cacheRead\":1.5}}"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.0"
  }
}
